// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   // 'Secondary Nutrients', 'Water Soluble Fertilizers', 'Liquid Fertilizers', 'Bio-Stimulants'
  description String?
  image       String?  // Image file name or URL
  packaging   String?  // e.g., '1 Kg, 25 Kg'
  usage       String?  // Recommended dosage/crops
  createdAt   DateTime @default(now())
}

model Inquiry {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  subject   String
  message   String
  status    String   @default("Pending") // 'Pending', 'Reviewed', 'Contacted'
  createdAt DateTime @default(now())
}

model GalleryItem {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  type      String   @default("image") // 'image' or 'video'
  createdAt DateTime @default(now())
}
